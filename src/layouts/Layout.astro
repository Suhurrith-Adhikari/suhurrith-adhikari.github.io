---
import "../styles/global.css";
interface Props { title?: string; description?: string; }
const {
  title = "Suhurrith Adhikari | Portfolio",
  description = "Portfolio of Suhurrith Adhikari — software engineering, AI, cybersecurity, and electrical engineering.",
} = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080c24" />
    <title>{title}</title>
    <script is:inline>
      try { document.documentElement.dataset.theme = localStorage.getItem("theme") || "dark"; } catch {}
    </script>
  </head>
  <body><slot /></body>
</html>
